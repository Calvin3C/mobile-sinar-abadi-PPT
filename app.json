{
  "expo": {
    "name": "Sinar Abadi",
    "slug": "sinar-abadi",
    "scheme": "sinarabadi",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "light",
    "newArchEnabled": true,
    "splash": {
      "image": "./assets/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#e11d48"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.sinarabadi.app"
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#e11d48"
      },
      "edgeToEdgeEnabled": true,
      "package": "com.sinarabadi.app"
    },
    "web": {
      "favicon": "./assets/favicon.png",
      "bundler": "metro"
    },
    "plugins": [
      "expo-router",
      "expo-secure-store",
      [
        "expo-image-picker",
        {
          "photosPermission": "Aplikasi memerlukan akses ke galeri untuk upload bukti pembayaran."
        }
      ],
      "@react-native-community/datetimepicker"
    ]
  }
}
